        const simbolos = document.querySelectorAll('.simbolo-tipo');
        const pergaminoTipos = document.getElementById('pergamino-tipos');
        const tituloTipo = document.getElementById('titulo-tipo');
        const descTipo = document.getElementById('desc-tipo');
        const carruselImagenesTipos = document.getElementById('carrusel-imagenes-tipos');

        let intervaloCarruselTipos;

        const sonidoCroac = new Audio('croac.mp3');
        sonidoCroac.volume = 0.6;
        sonidoCroac.preload = 'auto';

        simbolos.forEach(simbolo => {
            simbolo.addEventListener('click', function () {
                simbolos.forEach(s => s.classList.remove('seleccionado'));
                this.classList.add('seleccionado');

                const tipoSeleccionado = this.getAttribute('data-tipo');
                const infoSapo = baseDatosSapos[tipoSeleccionado];

                if (infoSapo) {
                    tituloTipo.textContent = infoSapo.titulo;
                    descTipo.textContent = infoSapo.desc;

                    carruselImagenesTipos.innerHTML = '';
                    infoSapo.imagenes.forEach((urlImg, index) => {
                        const nuevaImg = document.createElement('img');
                        nuevaImg.src = urlImg;
                        if (index === 0) nuevaImg.classList.add('active');
                        carruselImagenesTipos.appendChild(nuevaImg);
                    });

                    clearInterval(intervaloCarruselTipos);
                    if (infoSapo.imagenes.length > 1) {
                        let indiceTipos = 0;
                        const imagenesActivas = carruselImagenesTipos.querySelectorAll('img');
                        intervaloCarruselTipos = setInterval(() => {
                            imagenesActivas[indiceTipos].classList.remove('active');
                            indiceTipos = (indiceTipos + 1) % imagenesActivas.length;
                            imagenesActivas[indiceTipos].classList.add('active');
                        }, 3000);
                    }

                    pergaminoTipos.classList.add('abierto');
                }

                sonidoCroac.currentTime = 0;
                sonidoCroac.play().catch(e => console.log("Audio en espera de interacción"));
            });
        });

        let recaudado = 20000;
        const meta = 200000;
        const incremento = 5000;

        const btnDonar = document.getElementById('btn-donar');
        const barraProgreso = document.getElementById('funding-progress');
        const textoStats = document.getElementById('funding-stats');

        btnDonar.addEventListener('click', () => {
            if (recaudado < meta) {
                recaudado += incremento;

                const porcentaje = (recaudado / meta) * 100;
                barraProgreso.style.width = porcentaje + "%";
                textoStats.innerHTML = `<strong>${recaudado.toLocaleString()}€</strong> de <strong>${meta.toLocaleString()}€</strong> recaudados`;

                if (typeof sonidoCroac !== 'undefined') {
                    sonidoCroac.currentTime = 0;
                    sonidoCroac.play();
                }

                if (recaudado >= meta) {
                    btnDonar.textContent = "¡META ALCANZADA! GRACIAS";
                    btnDonar.style.background = "#4caf50";
                    confettiEfecto(); // Por si quieres añadir algo extra luego
                }
            }
